# ============================================
# Smart Document Chatbot - Monolith Dockerfile
# Bundles Frontend, Backend, Agent, Postgres, Qdrant, Ollama
# ============================================

# --- Stage 1: Build Backend ---
FROM maven:3.9-eclipse-temurin-17-alpine AS backend-builder
WORKDIR /build
COPY backend/pom.xml .
RUN mvn dependency:go-offline
COPY backend/src ./src
RUN mvn clean package -DskipTests

# --- Stage 2: Build Frontend ---
FROM node:18-alpine AS frontend-builder
WORKDIR /build
COPY frontend/package*.json ./
RUN npm install
COPY frontend/ .
RUN npm run build

# --- Stage 3: Final Monolith Image ---
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# 1. Install System Dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl wget gnupg2 lsb-release ca-certificates supervisor nginx sudo \
    openjdk-17-jre-headless python3.11 python3-pip \
    libpq-dev build-essential \
    && rm -rf /var/lib/apt/lists/*

# 2. Install PostgreSQL 15
RUN sh -c 'echo "deb http://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list' \
    && wget --quiet -O - https://www.postgresql.org/media/keys/ACCC4CF8.asc | apt-key add - \
    && apt-get update && apt-get install -y postgresql-15 \
    && rm -rf /var/lib/apt/lists/*

# 3. Install Qdrant
RUN QDRANT_VERSION="v1.7.4" && \
    wget https://github.com/qdrant/qdrant/releases/download/${QDRANT_VERSION}/qdrant-x86_64-unknown-linux-gnu.tar.gz && \
    tar -xvf qdrant-x86_64-unknown-linux-gnu.tar.gz && \
    mv qdrant /usr/local/bin/qdrant && \
    rm qdrant-x86_64-unknown-linux-gnu.tar.gz

# 4. Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# 5. Setup Application Directories
RUN mkdir -p /app/backend /app/agent /app/frontend /var/lib/qdrant/storage /var/run/postgresql

# 6. Copy Build Artifacts
COPY --from=backend-builder /build/target/*.jar /app/backend/app.jar
COPY --from=frontend-builder /build/dist /usr/share/nginx/html
COPY agent /app/agent

# 7. Setup Agent Environment
RUN pip3 install --no-cache-dir -r /app/agent/requirements.txt

# 8. Copy Configurations
COPY docker/supervisord.conf /etc/supervisor/conf.d/supervisord.conf
COPY docker/nginx.monolith.conf /etc/nginx/sites-available/default
COPY docker/qdrant_config.yaml /etc/qdrant/config.yaml
COPY docker/entrypoint.sh /app/entrypoint.sh
COPY .env /app/.env
RUN chmod +x /app/entrypoint.sh

# 9. Final Environment Settings
ENV POSTGRES_HOST=localhost
ENV POSTGRES_PORT=5432
ENV QDRANT_HOST=localhost
ENV QDRANT_PORT=6333
ENV LLM_BASE_URL=http://localhost:11434

# Expose ports
EXPOSE 80 8080 9000 6333 11434

# Entrypoint
ENTRYPOINT ["/app/entrypoint.sh"]
