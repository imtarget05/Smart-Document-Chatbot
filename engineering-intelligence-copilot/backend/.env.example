EIC_APP_NAME=Engineering Intelligence Copilot API
EIC_ENVIRONMENT=development
EIC_DEBUG=true
EIC_API_V1_PREFIX=/api/v1

EIC_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

EIC_DATABASE_URL=sqlite:///./engineering_copilot.db
EIC_QDRANT_URL=http://localhost:6333
EIC_QDRANT_COLLECTION=engineering_knowledge

EIC_LLM_PROVIDER=mock
EIC_LLM_MODEL=llama3.1:8b
EIC_EMBEDDING_PROVIDER=mock
EIC_EMBEDDING_MODEL=nomic-embed-text

EIC_JWT_SECRET_KEY=change-me
EIC_JWT_ALGORITHM=HS256
EIC_ACCESS_TOKEN_EXPIRE_MINUTES=60

EIC_UPLOAD_DIR=./uploads
EIC_MAX_UPLOAD_SIZE_MB=25
EIC_ALLOWED_EXTENSIONS=["pdf","docx","txt","md","csv","json"]