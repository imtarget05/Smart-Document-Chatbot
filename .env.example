# ============================================
# Smart Document Chatbot - Environment Variables
# Copy this file to .env and fill in actual values
# ============================================

# ---- Ollama LLM Server ----
# Model selection — choose ONE based on available RAM:
#   llama3.2:3b   → default, requires ~4 GB RAM  (fast, good for dev)
#   llama3.1:8b   → requires ~10 GB RAM          (better quality)
#   mistral:7b    → requires ~8 GB RAM           (good Vietnamese support)
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_KEEP_ALIVE=5m

# ---- LLM Router & embedding configuration ----
# Docker Compose injects http://llm-router:8000.
# When running backend locally (hot-reload), use http://localhost:8001.
LLM_BASE_URL=http://llm-router:8000
LLM_CHAT_MODEL=llama3.2:3b
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.3
LLM_ROUTER_PORT=8001
LOCAL_LLM_TIMEOUT_SECONDS=180
ROUTER_CONFIDENCE_THRESHOLD=0.7
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o

# ---- Database Configuration (Neon Serverless PostgreSQL - Free 512MB) ----
# Connection string from neon.tech
NEON_DATABASE_URL=postgresql://neondb_owner:npg_xxx@ep-xxx.aws.neon.tech/neondb?sslmode=require
# SPRING_DATASOURCE_URL=${NEON_DATABASE_URL}
# Local development fallbacks:
POSTGRES_DB=smart_doc_chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ---- Qdrant Configuration (Local/Cloud) ----
# Set host/key for Qdrant Cloud (cloud.qdrant.io)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_USE_HTTPS=false
QDRANT_API_KEY=qdrant_key_123
QDRANT_COLLECTION=documents

# ---- Storage Configuration (Supabase Storage - Free 1GB) ----
# Provider options: local | supabase
STORAGE_PROVIDER=local
SUPABASE_URL=https://your-project.supabase.co
# service_role key is required to bypass RLS for uploads
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=documents
LOCAL_UPLOAD_DIR=uploads

# ---- Spring Boot Configuration ----
SPRING_PROFILES_ACTIVE=default
SPRING_JPA_HIBERNATE_DDL_AUTO=update
FLYWAY_ENABLED=false
# Generate unique production values: openssl rand -base64 32 / openssl rand -hex 32
JWT_SECRET=replace-with-a-base64-encoded-32-byte-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-token
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:3000
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=replace-airflow-password

# ---- Server Ports ----
BACKEND_PORT=8080
FRONTEND_PORT=80

# ---- Frontend Build Args ----
VITE_API_URL=/api

# ---- JVM Configuration ----
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# ---- Logging ----
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SMARTDOCCHAT=DEBUG

# ============================================================
# Agent Service (LangGraph Multi-Agent Orchestration)
# ============================================================
AGENT_SERVICE_URL=http://agent:9000
AGENT_PORT=9000

# ---- Agent Security ----
# CORS: comma-separated browser origins allowed to call the agent directly.
# Internal Spring Boot calls bypass CORS (server-to-server, no browser involved).
# Production: set to your frontend domain only, e.g. https://app.yourdomain.com
AGENT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
# Max request body for agent endpoints (bytes). Default 512 KB = 524288.
# Per-IP rate limit on LLM-backed endpoints (requests/minute).
AGENT_RATE_LIMIT_RPM=20

# ---- Phase 1: Web Search (Researcher agent) ----
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# ---- Phase 3: Google Drive & Gmail Connector ----
# Download credentials.json from Google Cloud Console (OAuth2)
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# ---- Phase 3: Slack Connector ----
# Create a Slack App with channels:history scope
SLACK_BOT_TOKEN=

# ---- Phase 3: Connector Ingestion ----
CONNECTOR_CHUNK_SIZE=1200
CONNECTOR_CHUNK_OVERLAP=180

# ---- Phase 3: Microsoft SharePoint Connector ----
# Mock mode is enough for the fixed 8D demo scenario. Disable it and provide
# Graph values for a real SharePoint pull.
SHAREPOINT_MOCK_ENABLED=true
MICROSOFT_GRAPH_TOKEN=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# ---- Phase 4: Email Action (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ---- Phase 4: Jira Integration ----
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ---- Phase 4: Notion Integration ----
NOTION_API_TOKEN=

# ---- Phase 4: Microsoft Teams Webhook ----
TEAMS_WEBHOOK_URL=

# ---- Monitoring (optional) ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ---- NVIDIA NIM (Document Summarization) ----
NVIDIA_API_KEY=
NVIDIA_MODEL_ID=
NVIDIA_API_URL=https://api.nvcf.nvidia.com/v2/nvcf/pexec/functions
