# ============================================
# Smart Document Chatbot - Environment Variables
# Copy this file to .env and fill in actual values
# ============================================

# ---- Local LLM & Embedding Configuration (no AI provider API key required) ----
# Use http://localhost:11434 when running the backend outside Docker (e.g. localhost development).
LLM_BASE_URL=http://llm:11434
LLM_CHAT_MODEL=deepseek-r1:1.5b
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.3

# ---- Database Configuration ----
POSTGRES_DB=smart_doc_chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ---- Qdrant Configuration ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_key_123
QDRANT_COLLECTION=documents

# ---- Spring Boot Configuration ----
SPRING_PROFILES_ACTIVE=default
SPRING_JPA_HIBERNATE_DDL_AUTO=update
FLYWAY_ENABLED=false
# Generate unique production values: openssl rand -base64 32 / openssl rand -hex 32
JWT_SECRET=replace-with-a-base64-encoded-32-byte-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-token
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:3000
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=replace-airflow-password

# ---- Server Ports ----
BACKEND_PORT=8080
FRONTEND_PORT=80

# ---- Frontend Build Args ----
VITE_API_URL=/api

# ---- JVM Configuration ----
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# ---- Logging ----
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SMARTDOCCHAT=DEBUG

# ============================================================
# Agent Service (LangGraph Multi-Agent Orchestration)
# ============================================================
AGENT_SERVICE_URL=http://agent:9000
AGENT_PORT=9000

# ---- Phase 1: Web Search (Researcher agent) ----
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# ---- Phase 3: Google Drive & Gmail Connector ----
# Download credentials.json from Google Cloud Console (OAuth2)
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# ---- Phase 3: Slack Connector ----
# Create a Slack App with channels:history scope
SLACK_BOT_TOKEN=

# ---- Phase 4: Email Action (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ---- Phase 4: Jira Integration ----
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ---- Phase 4: Notion Integration ----
NOTION_API_TOKEN=

# ---- Monitoring (optional) ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
