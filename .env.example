# ============================================
# Smart Document Chatbot - Environment Variables
# Copy this file to .env and fill in actual values
# ============================================

# ---- OpenRouter / Local LLM Configuration (Chat LLM) ----
# To run completely offline locally with DeepSeek:
# Set OPENROUTER_CHAT_URL=http://ollama:11434/v1/chat/completions
# Set OPENROUTER_MODEL=deepseek-r1:1.5b
# Set OPENROUTER_API_KEY=local_no_key_required
OPENROUTER_CHAT_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_TEMPERATURE=0.3

# ---- Gemini Configuration (Embeddings only) ----
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ---- Database Configuration ----
POSTGRES_DB=smart_doc_chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ---- Qdrant Configuration ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_key_123
QDRANT_COLLECTION=documents

# ---- Spring Boot Configuration ----
SPRING_PROFILES_ACTIVE=default
SPRING_JPA_HIBERNATE_DDL_AUTO=update
FLYWAY_ENABLED=false

# ---- Server Ports ----
BACKEND_PORT=8080
FRONTEND_PORT=80

# ---- Frontend Build Args ----
REACT_APP_API_URL=/api
REACT_APP_WS_URL=/ws

# ---- JVM Configuration ----
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# ---- Logging ----
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SMARTDOCCHAT=DEBUG

# ---- Monitoring (optional) ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
