# ============================================================================
# Smart Document Chatbot — Environment Configuration (TEMPLATE)
# ============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# All secrets below are intentionally blank — you MUST provide strong values.
# Generate strong secrets with, e.g.:
#   openssl rand -base64 48        # for JWT_SECRET / INTERNAL_SERVICE_TOKEN
#   openssl rand -base64 24        # for service passwords
# ============================================================================

# --- Deployment Environment ---
# local | dev | staging | production
# In non-local envs, the agent service enforces strict secret validation.
APP_ENV=local

# --- LLM Configuration (local Ollama only) ---
# All LLM requests are served by local Ollama — no external API keys needed.
OLLAMA_BASE_URL=http://host.docker.internal:11434
LOCAL_CHAT_MODEL_SIMPLE=llama3.2:3b
LOCAL_CHAT_MODEL_COMPLEX=qwen2.5:32b-instruct
LOCAL_EMBED_MODEL=nomic-embed-text
LOCAL_LLM_TIMEOUT_SECONDS=180

# --- Agent Configuration ---
# Comma-separated CORS origins. In production, set to explicit domains only
# (NO localhost / 127.0.0.1).
AGENT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AGENT_MAX_REQUEST_BYTES=524288
AGENT_RATE_LIMIT_RPM=30
# MUST be >= 32 chars in non-local envs. Generate: openssl rand -base64 48
INTERNAL_SERVICE_TOKEN=

# --- Database ---
DATABASE_URL=jdbc:postgresql://localhost:5432/smart_doc_chatbot
POSTGRES_USER=postgres
# MUST be >= 12 chars in non-local envs. Generate: openssl rand -base64 24
POSTGRES_PASSWORD=
POSTGRES_DB=smart_doc_chatbot

# --- Vector Store ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Leave empty for local unauthenticated Qdrant; set real key for Qdrant Cloud.
QDRANT_API_KEY=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Monitoring ---
MLFLOW_TRACKING_URI=http://localhost:5000
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# --- Server ---
SERVER_PORT=8080
AGENT_SERVICE_URL=http://agent:8000
LOG_LEVEL=INFO

# --- Security ---
# MUST be a cryptographically random base64 string >= 32 bytes.
# Generate: openssl rand -base64 48
JWT_SECRET=
UPLOAD_MAX_FILE_SIZE=10485760
